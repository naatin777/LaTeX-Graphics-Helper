{
  "name": "latex-graphics-helper",
  "displayName": "LaTeX Graphics Helper",
  "version": "1.0.0",
  "description": "PDF and image tools for VS Code, including trimming, merging, splitting, conversion, Draw.io export, and LaTeX figure insertion.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "drawio",
    "image",
    "latex",
    "pdf",
    "tex"
  ],
  "homepage": "https://github.com/naatin777/LaTeX-Graphics-Helper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/naatin777/LaTeX-Graphics-Helper"
  },
  "publisher": "naatin777",
  "type": "module",
  "main": "./out/extension.js",
  "scripts": {
    "clean": "node -e \"const fs = require('node:fs'); for (const p of ['out', 'media/webview']) fs.rmSync(p, { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:webview": "tsc --noEmit -p webview/tsconfig.json",
    "typecheck:webview:test": "tsc --noEmit -p webview/tsconfig.test.json",
    "lint": "oxlint src test webview/apps webview/shared",
    "lint:fix": "oxlint --fix src test webview/apps webview/shared",
    "format": "oxfmt --config ./oxfmt.config.ts --check src test webview/apps webview/shared package.json tsconfig.json tsconfig.test.json webview/tsconfig.json webview/tsconfig.test.json oxfmt.config.ts oxlint.config.ts",
    "format:fix": "oxfmt --config ./oxfmt.config.ts --write src test webview/apps webview/shared package.json tsconfig.json tsconfig.test.json webview/tsconfig.json webview/tsconfig.test.json oxfmt.config.ts oxlint.config.ts",
    "compile": "tsc -p tsconfig.json",
    "compile:test": "tsc -p tsconfig.test.json",
    "compile:webview": "npm run compile:webview:crop_pdf && npm run compile:webview:merge_pdf && npm run compile:webview:split_pdf",
    "compile:webview:crop_pdf": "vite build --config webview/apps/crop_pdf/vite.config.ts",
    "compile:webview:merge_pdf": "vite build --config webview/apps/merge_pdf/vite.config.ts",
    "compile:webview:split_pdf": "vite build --config webview/apps/split_pdf/vite.config.ts",
    "test:webview": "npm run test:webview:crop_pdf && npm run test:webview:merge_pdf && npm run test:webview:split_pdf",
    "test:webview:crop_pdf": "vitest run --config webview/apps/crop_pdf/vitest.config.ts",
    "test:webview:merge_pdf": "vitest run --config webview/apps/merge_pdf/vitest.config.ts",
    "test:webview:split_pdf": "vitest run --config webview/apps/split_pdf/vitest.config.ts",
    "build": "npm run clean && npm run compile && npm run compile:test && npm run compile:webview",
    "check": "npm run lint && npm run format && npm run typecheck && npm run typecheck:test && npm run typecheck:webview && npm run typecheck:webview:test",
    "check:nls": "node scripts/check-nls.mjs",
    "check:all": "npm run check && npm run check:nls",
    "check:fix": "npm run lint:fix && npm run format:fix",
    "test": "vscode-test",
    "test:playwright": "playwright test --project=vscode-electron",
    "test:playwright:vsix": "playwright test --project=vscode-electron",
    "package": "npm run build && npm run package:vsix",
    "package:vsix": "node scripts/package-vsix.mjs"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.16.0",
    "p-limit": "^7.3.0",
    "pdf-lib": "^1.17.1",
    "puppeteer-core": "^25.3.0",
    "sharp": "^0.35.3",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.20.0",
    "@types/sinon": "^22.0.0",
    "@types/vscode": "^1.105.0",
    "@types/xml2js": "^0.4.14",
    "@vscode/test-cli": "^0.0.11",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "jsdom": "^29.1.1",
    "lefthook": "2.1.10",
    "mocha": "^11.3.0",
    "ovsx": "^1.0.2",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "oxlint-tsgolint": "^0.25.0",
    "pdfjs-dist": "^6.1.200",
    "sinon": "^22.0.0",
    "solid-js": "^1.9.14",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.10"
  },
  "contributes": {
    "commands": [
      {
        "command": "latex-graphics-helper.cropPdf.auto",
        "title": "%command.cropPdf.auto%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.undoLastConversion",
        "title": "%command.undoLastConversion%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.toggleSafeMode",
        "title": "%command.toggleSafeMode%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.cropPdf.configure",
        "title": "%command.cropPdf.configure%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.splitPdf.allPages",
        "title": "%command.splitPdf.allPages%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.splitPdf.configure",
        "title": "%command.splitPdf.configure%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.mergePdf.selectedFiles",
        "title": "%command.mergePdf.selectedFiles%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.mergePdf.configure",
        "title": "%command.mergePdf.configure%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToPdf",
        "title": "%command.convertToPdf%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertDrawioToPdf",
        "title": "%command.convertDrawioToPdf%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertDrawioToPdfDirectly",
        "title": "%command.convertDrawioToPdfDirectly%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToPng",
        "title": "%command.convertToPng%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToJpeg",
        "title": "%command.convertToJpeg%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToWebp",
        "title": "%command.convertToWebp%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToAvif",
        "title": "%command.convertToAvif%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToSvg",
        "title": "%command.convertToSvg%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertImagesToSinglePdf",
        "title": "%command.convertImagesToSinglePdf%",
        "category": "LaTeX Graphics Helper"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "latex-graphics-helper.cropPdf",
          "group": "latex-graphics-helper",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.cropPdf.enabled"
        },
        {
          "submenu": "latex-graphics-helper.splitPdf",
          "group": "latex-graphics-helper",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.splitPdf.enabled"
        },
        {
          "submenu": "latex-graphics-helper.mergePdf",
          "group": "latex-graphics-helper",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.mergePdf.enabled"
        },
        {
          "submenu": "latex-graphics-helper.convert",
          "group": "latex-graphics-helper",
          "when": "config.latex-graphics-helper.contextMenu.enabled && ((resourceExtname =~ /^\\.pdf$/i && config.latex-graphics-helper.contextMenu.convertPdf.enabled) || (resourceExtname =~ /^\\.png$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertPng.enabled) || (resourceExtname =~ /^\\.(jpg|jpeg)$/i && config.latex-graphics-helper.contextMenu.convertJpeg.enabled) || (resourceExtname =~ /^\\.webp$/i && config.latex-graphics-helper.contextMenu.convertWebp.enabled) || (resourceExtname =~ /^\\.avif$/i && config.latex-graphics-helper.contextMenu.convertAvif.enabled) || resourceExtname =~ /^\\.(gif|tif|tiff|eps)$/i || (resourceExtname =~ /^\\.svg$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertSvg.enabled) || (resourceExtname =~ /^\\.(mmd|mermaid)$/i && config.latex-graphics-helper.contextMenu.convertMermaid.enabled) || (resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i && config.latex-graphics-helper.contextMenu.convertDrawio.enabled))"
        },
        {
          "command": "latex-graphics-helper.convertDrawioToPdf",
          "group": "latex-graphics-helper",
          "when": "(resourceExtname =~ /^\\.(drawio|dio)$/i || resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.convertDrawio.enabled"
        },
        {
          "command": "latex-graphics-helper.convertDrawioToPdfDirectly",
          "group": "latex-graphics-helper",
          "when": "(resourceExtname =~ /^\\.(drawio|dio)$/i || resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.convertDrawio.enabled"
        },
        {
          "command": "latex-graphics-helper.convertImagesToSinglePdf",
          "group": "latex-graphics-helper.convert@7",
          "when": "config.latex-graphics-helper.contextMenu.enabled && ((resourceExtname =~ /^\\.png$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertPng.enabled) || (resourceExtname =~ /^\\.(jpg|jpeg)$/i && config.latex-graphics-helper.contextMenu.convertJpeg.enabled) || (resourceExtname =~ /^\\.webp$/i && config.latex-graphics-helper.contextMenu.convertWebp.enabled) || (resourceExtname =~ /^\\.avif$/i && config.latex-graphics-helper.contextMenu.convertAvif.enabled) || resourceExtname =~ /^\\.(gif|tif|tiff|eps)$/i || (resourceExtname =~ /^\\.svg$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertSvg.enabled))"
        }
      ],
      "latex-graphics-helper.cropPdf": [
        {
          "command": "latex-graphics-helper.cropPdf.auto",
          "group": "latex-graphics-helper.cropPdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.cropPdf.enabled"
        },
        {
          "command": "latex-graphics-helper.cropPdf.configure",
          "group": "latex-graphics-helper.cropPdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.cropPdf.enabled"
        }
      ],
      "latex-graphics-helper.splitPdf": [
        {
          "command": "latex-graphics-helper.splitPdf.allPages",
          "group": "latex-graphics-helper.splitPdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.splitPdf.enabled"
        },
        {
          "command": "latex-graphics-helper.splitPdf.configure",
          "group": "latex-graphics-helper.splitPdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.splitPdf.enabled"
        }
      ],
      "latex-graphics-helper.mergePdf": [
        {
          "command": "latex-graphics-helper.mergePdf.selectedFiles",
          "group": "latex-graphics-helper.mergePdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.mergePdf.enabled"
        },
        {
          "command": "latex-graphics-helper.mergePdf.configure",
          "group": "latex-graphics-helper.mergePdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.mergePdf.enabled"
        }
      ],
      "latex-graphics-helper.convert": [
        {
          "command": "latex-graphics-helper.convertToPdf",
          "group": "latex-graphics-helper.convert@1",
          "when": "config.latex-graphics-helper.contextMenu.enabled && ((resourceExtname =~ /^\\.png$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertPng.enabled) || (resourceExtname =~ /^\\.(jpg|jpeg)$/i && config.latex-graphics-helper.contextMenu.convertJpeg.enabled) || (resourceExtname =~ /^\\.webp$/i && config.latex-graphics-helper.contextMenu.convertWebp.enabled) || (resourceExtname =~ /^\\.avif$/i && config.latex-graphics-helper.contextMenu.convertAvif.enabled) || resourceExtname =~ /^\\.(gif|tif|tiff)$/i || (resourceExtname =~ /^\\.(mmd|mermaid)$/i && config.latex-graphics-helper.contextMenu.convertMermaid.enabled) || (resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i && config.latex-graphics-helper.contextMenu.convertDrawio.enabled))"
        },
        {
          "command": "latex-graphics-helper.convertToPng",
          "group": "latex-graphics-helper.convert@2",
          "when": "config.latex-graphics-helper.contextMenu.enabled && ((resourceExtname =~ /^\\.pdf$/i && config.latex-graphics-helper.contextMenu.convertPdf.enabled) || (resourceExtname =~ /^\\.(jpg|jpeg)$/i && config.latex-graphics-helper.contextMenu.convertJpeg.enabled) || (resourceExtname =~ /^\\.webp$/i && config.latex-graphics-helper.contextMenu.convertWebp.enabled) || (resourceExtname =~ /^\\.avif$/i && config.latex-graphics-helper.contextMenu.convertAvif.enabled) || resourceExtname =~ /^\\.(gif|tif|tiff)$/i || (resourceExtname =~ /^\\.svg$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertSvg.enabled) || (resourceExtname =~ /^\\.(mmd|mermaid)$/i && config.latex-graphics-helper.contextMenu.convertMermaid.enabled) || (resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i && config.latex-graphics-helper.contextMenu.convertDrawio.enabled))"
        },
        {
          "command": "latex-graphics-helper.convertToJpeg",
          "group": "latex-graphics-helper.convert@3",
          "when": "config.latex-graphics-helper.contextMenu.enabled && ((resourceExtname =~ /^\\.pdf$/i && config.latex-graphics-helper.contextMenu.convertPdf.enabled) || (resourceExtname =~ /^\\.png$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertPng.enabled) || (resourceExtname =~ /^\\.webp$/i && config.latex-graphics-helper.contextMenu.convertWebp.enabled) || (resourceExtname =~ /^\\.avif$/i && config.latex-graphics-helper.contextMenu.convertAvif.enabled) || resourceExtname =~ /^\\.(gif|tif|tiff)$/i || (resourceExtname =~ /^\\.svg$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertSvg.enabled) || (resourceExtname =~ /^\\.(mmd|mermaid)$/i && config.latex-graphics-helper.contextMenu.convertMermaid.enabled) || (resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i && config.latex-graphics-helper.contextMenu.convertDrawio.enabled))"
        },
        {
          "command": "latex-graphics-helper.convertToWebp",
          "group": "latex-graphics-helper.convert@4",
          "when": "config.latex-graphics-helper.contextMenu.enabled && ((resourceExtname =~ /^\\.pdf$/i && config.latex-graphics-helper.contextMenu.convertPdf.enabled) || (resourceExtname =~ /^\\.png$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertPng.enabled) || (resourceExtname =~ /^\\.(jpg|jpeg)$/i && config.latex-graphics-helper.contextMenu.convertJpeg.enabled) || (resourceExtname =~ /^\\.avif$/i && config.latex-graphics-helper.contextMenu.convertAvif.enabled) || resourceExtname =~ /^\\.(gif|tif|tiff)$/i || (resourceExtname =~ /^\\.svg$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertSvg.enabled) || (resourceExtname =~ /^\\.(mmd|mermaid)$/i && config.latex-graphics-helper.contextMenu.convertMermaid.enabled) || (resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i && config.latex-graphics-helper.contextMenu.convertDrawio.enabled))"
        },
        {
          "command": "latex-graphics-helper.convertToAvif",
          "group": "latex-graphics-helper.convert@5",
          "when": "config.latex-graphics-helper.contextMenu.enabled && ((resourceExtname =~ /^\\.pdf$/i && config.latex-graphics-helper.contextMenu.convertPdf.enabled) || (resourceExtname =~ /^\\.png$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertPng.enabled) || (resourceExtname =~ /^\\.(jpg|jpeg)$/i && config.latex-graphics-helper.contextMenu.convertJpeg.enabled) || (resourceExtname =~ /^\\.webp$/i && config.latex-graphics-helper.contextMenu.convertWebp.enabled) || resourceExtname =~ /^\\.(gif|tif|tiff)$/i || (resourceExtname =~ /^\\.svg$/i && !(resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i) && config.latex-graphics-helper.contextMenu.convertSvg.enabled) || (resourceExtname =~ /^\\.(mmd|mermaid)$/i && config.latex-graphics-helper.contextMenu.convertMermaid.enabled) || (resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i && config.latex-graphics-helper.contextMenu.convertDrawio.enabled))"
        },
        {
          "command": "latex-graphics-helper.convertToSvg",
          "group": "latex-graphics-helper.convert@6",
          "when": "config.latex-graphics-helper.contextMenu.enabled && ((resourceExtname =~ /^\\.pdf$/i && config.latex-graphics-helper.contextMenu.convertPdf.enabled) || (resourceExtname =~ /^\\.(mmd|mermaid)$/i && config.latex-graphics-helper.contextMenu.convertMermaid.enabled) || (resourceFilename =~ /\\.(drawio|dio)\\.(png|svg)$/i && config.latex-graphics-helper.contextMenu.convertDrawio.enabled))"
        }
      ],
      "commandPalette": [
        {
          "command": "latex-graphics-helper.cropPdf.auto",
          "when": "false"
        },
        {
          "command": "latex-graphics-helper.cropPdf.configure",
          "when": "false"
        },
        {
          "command": "latex-graphics-helper.splitPdf.configure",
          "when": "false"
        },
        {
          "command": "latex-graphics-helper.mergePdf.configure",
          "when": "false"
        },
        {
          "command": "latex-graphics-helper.convertDrawioToPdf",
          "when": "false"
        },
        {
          "command": "latex-graphics-helper.convertDrawioToPdfDirectly",
          "when": "false"
        },
        {
          "command": "latex-graphics-helper.convertImagesToSinglePdf",
          "when": "false"
        }
      ]
    },
    "submenus": [
      {
        "id": "latex-graphics-helper.cropPdf",
        "label": "%submenu.cropPdf%"
      },
      {
        "id": "latex-graphics-helper.splitPdf",
        "label": "%submenu.splitPdf%"
      },
      {
        "id": "latex-graphics-helper.mergePdf",
        "label": "%submenu.mergePdf%"
      },
      {
        "id": "latex-graphics-helper.convert",
        "label": "%submenu.convert%"
      }
    ],
    "configuration": {
      "title": "LaTeX Graphics Helper",
      "properties": {
        "latex-graphics-helper.execPath.drawio": {
          "type": "string",
          "default": "",
          "description": "%config.execPath.drawio%"
        },
        "latex-graphics-helper.execPath.ghostscript": {
          "type": "string",
          "default": "",
          "description": "%config.execPath.ghostscript%"
        },
        "latex-graphics-helper.execPath.pdftocairo": {
          "type": "string",
          "default": "pdftocairo",
          "description": "%config.execPath.pdftocairo%"
        },
        "latex-graphics-helper.execPath.rsvgConvert": {
          "type": "string",
          "default": "rsvg-convert",
          "description": "%config.execPath.rsvgConvert%"
        },
        "latex-graphics-helper.convertToPdf.svg.engine": {
          "type": "string",
          "enum": [
            "puppeteer",
            "rsvg-convert"
          ],
          "default": "puppeteer",
          "description": "%config.convertToPdf.svg.engine%"
        },
        "latex-graphics-helper.convertToPdf.svg.puppeteer.browserChannel": {
          "type": "string",
          "enum": [
            "chrome",
            "chrome-beta",
            "chrome-dev",
            "chrome-canary"
          ],
          "default": "chrome",
          "description": "%config.convertToPdf.svg.puppeteer.browserChannel%"
        },
        "latex-graphics-helper.convertToPdf.svg.puppeteer.executablePath": {
          "type": "string",
          "default": "",
          "description": "%config.convertToPdf.svg.puppeteer.executablePath%"
        },
        "latex-graphics-helper.convertToPdf.mermaid.puppeteer.browserChannel": {
          "type": "string",
          "enum": [
            "chrome",
            "chrome-beta",
            "chrome-dev",
            "chrome-canary"
          ],
          "default": "chrome",
          "description": "%config.convertToPdf.mermaid.puppeteer.browserChannel%"
        },
        "latex-graphics-helper.convertToPdf.mermaid.puppeteer.executablePath": {
          "type": "string",
          "default": "",
          "description": "%config.convertToPdf.mermaid.puppeteer.executablePath%"
        },
        "latex-graphics-helper.convertToSvg.mermaid.puppeteer.browserChannel": {
          "type": "string",
          "enum": [
            "chrome",
            "chrome-beta",
            "chrome-dev",
            "chrome-canary"
          ],
          "default": "chrome",
          "description": "%config.convertToSvg.mermaid.puppeteer.browserChannel%"
        },
        "latex-graphics-helper.convertToSvg.mermaid.puppeteer.executablePath": {
          "type": "string",
          "default": "",
          "description": "%config.convertToSvg.mermaid.puppeteer.executablePath%"
        },
        "latex-graphics-helper.mermaid.puppeteer.browserChannel": {
          "type": "string",
          "enum": [
            "chrome",
            "chrome-beta",
            "chrome-dev",
            "chrome-canary"
          ],
          "default": "chrome",
          "description": "%config.mermaid.puppeteer.browserChannel%"
        },
        "latex-graphics-helper.mermaid.theme": {
          "type": "string",
          "enum": [
            "default",
            "forest",
            "dark",
            "neutral",
            "base"
          ],
          "default": "default",
          "description": "%config.mermaid.theme%"
