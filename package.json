{
  "name": "latex-graphics-helper",
  "displayName": "LaTeX Graphics Helper",
  "version": "1.0.0",
  "description": "PDF and image tools for VS Code, including trimming, merging, splitting, conversion, Draw.io export, and LaTeX figure insertion.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "drawio",
    "image",
    "latex",
    "pdf",
    "tex"
  ],
  "homepage": "https://github.com/naatin777/LaTeX-Graphics-Helper",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/naatin777/LaTeX-Graphics-Helper"
  },
  "publisher": "naatin777",
  "type": "module",
  "main": "./out/extension.js",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "typecheck:test": "tsc --noEmit -p tsconfig.test.json",
    "typecheck:webview": "tsc --noEmit -p webview/tsconfig.json",
    "typecheck:webview:test": "tsc --noEmit -p webview/tsconfig.test.json",
    "compile": "tsc -p tsconfig.json",
    "compile:test": "tsc -p tsconfig.test.json",
    "compile:webview": "pnpm run compile:webview:crop_pdf && pnpm run compile:webview:merge_pdf",
    "compile:webview:crop_pdf": "vite build --config webview/apps/crop_pdf/vite.config.ts",
    "compile:webview:merge_pdf": "vite build --config webview/apps/merge_pdf/vite.config.ts",
    "build": "pnpm run clean && pnpm run compile && pnpm run compile:webview",
    "build:test": "pnpm run clean && pnpm run compile && pnpm run compile:test && pnpm run compile:webview",
    "watch": "tsc --watch -p tsconfig.json",
    "watch:webview:crop_pdf": "vite build --watch --config webview/apps/crop_pdf/vite.config.ts",
    "watch:webview:merge_pdf": "vite build --watch --config webview/apps/merge_pdf/vite.config.ts",
    "lint": "oxlint src test webview/apps webview/shared webview/vite.config.ts webview/vitest.config.ts oxlint.config.ts",
    "lint:fix": "oxlint --fix src test webview/apps webview/shared webview/vite.config.ts webview/vitest.config.ts oxlint.config.ts",
    "format": "oxfmt --check src test webview/apps webview/shared webview/vite.config.ts webview/vitest.config.ts package.json tsconfig.json tsconfig.test.json webview/tsconfig.json webview/tsconfig.test.json oxfmt.config.ts oxlint.config.ts",
    "format:fix": "oxfmt --write src test webview/apps webview/shared webview/vite.config.ts webview/vitest.config.ts package.json tsconfig.json tsconfig.test.json webview/tsconfig.json webview/tsconfig.test.json oxfmt.config.ts oxlint.config.ts",
    "check": "pnpm run lint && pnpm run format && pnpm run typecheck && pnpm run typecheck:webview",
    "check:test": "pnpm run typecheck:test && pnpm run typecheck:webview:test",
    "check:all": "pnpm run check && pnpm run check:test",
    "check:fix": "pnpm run lint:fix && pnpm run format:fix",
    "rulesync:generate": "rulesync generate",
    "rulesync:check": "rulesync generate --check",
    "clean": "node -e \"const fs = require('node:fs'); for (const p of ['out', 'media/webview']) fs.rmSync(p, { recursive: true, force: true })\"",
    "test": "pnpm run test:vscode",
    "test:vscode": "pnpm run build:test && vscode-test",
    "test:playwright": "pnpm run build && playwright test",
    "test:all": "pnpm run test:vscode && pnpm run test:playwright",
    "package": "pnpm run build && vsce package"
  },
  "dependencies": {
    "@mermaid-js/mermaid-cli": "^11.15.0",
    "p-limit": "^7.3.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^6.0.227",
    "puppeteer-core": "^25.2.1",
    "sharp": "^0.34.5",
    "solid-js": "^1.9.13",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.19.21",
    "@types/sinon": "^21.0.1",
    "@types/vscode": "^1.105.0",
    "@types/xml2js": "^0.4.14",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "jsdom": "^29.1.1",
    "lefthook": "^2.1.9",
    "mocha": "^11.7.6",
    "ovsx": "^1.0.1",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.70.0",
    "rulesync": "8.31.0",
    "sinon": "^22.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vite-plugin-solid": "^2.11.12",
    "vitest": "^4.1.9"
  },
  "contributes": {
    "commands": [
      {
        "command": "latex-graphics-helper.cropPdf.auto",
        "title": "%command.cropPdf.auto%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.undoLastConversion",
        "title": "%command.undoLastConversion%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.toggleSafeMode",
        "title": "%command.toggleSafeMode%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.cropPdf.manual",
        "title": "%command.cropPdf.manual%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.splitPdf.allPages",
        "title": "%command.splitPdf.allPages%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.splitPdf.manual",
        "title": "%command.splitPdf.manual%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.mergePdf.selectedPages",
        "title": "%command.mergePdf.selectedPages%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.mergePdf.manual",
        "title": "%command.mergePdf.manual%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToPdf",
        "title": "%command.convertToPdf%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToPng",
        "title": "%command.convertToPng%",
        "category": "LaTeX Graphics Helper"
      },
      {
        "command": "latex-graphics-helper.convertToSvg",
        "title": "%command.convertToSvg%",
        "category": "LaTeX Graphics Helper"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "submenu": "latex-graphics-helper.cropPdf",
          "group": "latex-graphics-helper",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.cropPdf.enabled"
        },
        {
          "submenu": "latex-graphics-helper.splitPdf",
          "group": "latex-graphics-helper",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.splitPdf.enabled"
        },
        {
          "submenu": "latex-graphics-helper.mergePdf",
          "group": "latex-graphics-helper",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.mergePdf.enabled"
        },
        {
          "submenu": "latex-graphics-helper.convert",
          "group": "latex-graphics-helper",
          "when": "resourceExtname =~ /^\\.(pdf|png|jpg|jpeg|webp|avif|svg|mmd|mermaid)$/ && config.latex-graphics-helper.contextMenu.enabled"
        }
      ],
      "latex-graphics-helper.cropPdf": [
        {
          "command": "latex-graphics-helper.cropPdf.auto",
          "group": "latex-graphics-helper.cropPdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.cropPdf.enabled"
        },
        {
          "command": "latex-graphics-helper.cropPdf.manual",
          "group": "latex-graphics-helper.cropPdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.cropPdf.enabled"
        }
      ],
      "latex-graphics-helper.splitPdf": [
        {
          "command": "latex-graphics-helper.splitPdf.allPages",
          "group": "latex-graphics-helper.splitPdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.splitPdf.enabled"
        },
        {
          "command": "latex-graphics-helper.splitPdf.manual",
          "group": "latex-graphics-helper.splitPdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.splitPdf.enabled"
        }
      ],
      "latex-graphics-helper.mergePdf": [
        {
          "command": "latex-graphics-helper.mergePdf.selectedPages",
          "group": "latex-graphics-helper.mergePdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.mergePdf.enabled"
        },
        {
          "command": "latex-graphics-helper.mergePdf.manual",
          "group": "latex-graphics-helper.mergePdf",
          "when": "resourceExtname == .pdf && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.mergePdf.enabled"
        }
      ],
      "latex-graphics-helper.convert": [
        {
          "command": "latex-graphics-helper.convertToPdf",
          "group": "latex-graphics-helper.convert@1",
          "when": "resourceExtname =~ /^\\.(png|jpg|jpeg|webp|avif|mmd|mermaid)$/ && config.latex-graphics-helper.contextMenu.enabled"
        },
        {
          "command": "latex-graphics-helper.convertToPng",
          "group": "latex-graphics-helper.convert@2",
          "when": "resourceExtname =~ /^\\.(pdf|jpg|jpeg|webp|avif|svg)$/ && config.latex-graphics-helper.contextMenu.enabled"
        },
        {
          "command": "latex-graphics-helper.convertToSvg",
          "group": "latex-graphics-helper.convert@6",
          "when": "resourceExtname =~ /^\\.(mmd|mermaid)$/ && config.latex-graphics-helper.contextMenu.enabled && config.latex-graphics-helper.contextMenu.convertMermaid.enabled"
        }
      ],
      "commandPalette": [
        {
          "command": "latex-graphics-helper.cropPdf.auto",
          "when": "false"
        }
      ]
    },
    "submenus": [
      {
        "id": "latex-graphics-helper.cropPdf",
        "label": "%submenu.cropPdf%"
      },
      {
        "id": "latex-graphics-helper.splitPdf",
        "label": "%submenu.splitPdf%"
      },
      {
        "id": "latex-graphics-helper.mergePdf",
        "label": "%submenu.mergePdf%"
      },
      {
        "id": "latex-graphics-helper.convert",
        "label": "%submenu.convert%"
      }
    ],
    "configuration": {
      "title": "LaTeX Graphics Helper",
      "properties": {
        "latex-graphics-helper.execPath.drawio": {
          "type": "string",
          "default": "",
          "description": "%config.execPath.drawio%"
        },
        "latex-graphics-helper.execPath.ghostscript": {
          "type": "string",
          "default": "",
          "description": "%config.execPath.ghostscript%"
        },
        "latex-graphics-helper.execPath.pdftocairo": {
          "type": "string",
          "default": "pdftocairo",
          "description": "%config.execPath.pdftocairo%"
        },
        "latex-graphics-helper.execPath.rsvgConvert": {
          "type": "string",
          "default": "rsvg-convert",
          "description": "%config.execPath.rsvgConvert%"
        },
        "latex-graphics-helper.convertToPdf.svg.engine": {
          "type": "string",
          "enum": [
            "puppeteer",
            "rsvg-convert"
          ],
          "default": "puppeteer",
          "description": "%config.convertToPdf.svg.engine%"
        },
        "latex-graphics-helper.convertToPdf.svg.puppeteer.browserChannel": {
          "type": "string",
          "enum": [
            "chrome",
            "chrome-beta",
            "chrome-dev",
            "chrome-canary"
          ],
          "default": "chrome",
          "description": "%config.convertToPdf.svg.puppeteer.browserChannel%"
        },
        "latex-graphics-helper.convertToPdf.svg.puppeteer.executablePath": {
          "type": "string",
          "default": "",
          "description": "%config.convertToPdf.svg.puppeteer.executablePath%"
        },
        "latex-graphics-helper.convertToPdf.mermaid.puppeteer.browserChannel": {
          "type": "string",
          "enum": [
            "chrome",
            "chrome-beta",
            "chrome-dev",
            "chrome-canary"
          ],
          "default": "chrome",
          "description": "%config.convertToPdf.mermaid.puppeteer.browserChannel%"
        },
        "latex-graphics-helper.convertToPdf.mermaid.puppeteer.executablePath": {
          "type": "string",
          "default": "",
          "description": "%config.convertToPdf.mermaid.puppeteer.executablePath%"
        },
        "latex-graphics-helper.convertToSvg.mermaid.puppeteer.browserChannel": {
          "type": "string",
          "enum": [
            "chrome",
            "chrome-beta",
            "chrome-dev",
            "chrome-canary"
          ],
          "default": "chrome",
          "description": "%config.convertToSvg.mermaid.puppeteer.browserChannel%"
        },
        "latex-graphics-helper.convertToSvg.mermaid.puppeteer.executablePath": {
          "type": "string",
          "default": "",
          "description": "%config.convertToSvg.mermaid.puppeteer.executablePath%"
        },
        "latex-graphics-helper.outputPath.cropPdf": {
          "type": "string",
          "default": "${fileDirname}/${fileBasenameNoExtension}-crop.pdf",
          "description": "%config.outputPath.cropPdf%"
        },
        "latex-graphics-helper.outputPath.splitPdf": {
          "type": "string",
          "default": "${fileDirname}/${fileBasenameNoExtension}/${page}.pdf",
          "description": "%config.outputPath.splitPdf%"
        },
        "latex-graphics-helper.cropPdf.marginOptions": {
          "type": "array",
          "items": {
            "type": "number",
            "minimum": 0
          },
          "default": [
            0,
            5,
            10,
            20
          ],
          "description": "%config.cropPdf.marginOptions%"
        },
        "latex-graphics-helper.outputPath.convertDrawioToPdf": {
