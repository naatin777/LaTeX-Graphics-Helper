{
	"compilerOptions": {
		"module": "Node16",
		"moduleResolution": "Node16",
		"target": "ES2022",
		"lib": [
			"ES2022"
		],
		"outDir": "out",
		"rootDir": "src",
		"sourceMap": true,
		"strict": true,
		"resolveJsonModule": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"types": [
			"mocha",
			"node"
		]
	},
	"include": [
		"src/**/*"
	],
	"exclude": [
		"out",
		"node_modules",
		".vscode-test"
	]
}
