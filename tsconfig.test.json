{
  // 本番用の厳格設定を継承する。
  "extends": "./tsconfig.json",
  "compilerOptions": {
    // test/ も含めるため、ルートをプロジェクト直下に広げる。
    "rootDir": ".",
    "outDir": "out",
    // テストコードで mocha の describe / it などを使えるようにする。
    "types": ["node", "mocha"]
  },
  // 本番コードとテストコードの両方を型チェック対象にする。
  "include": ["src/**/*", "test/**/*"],
  "exclude": [
    "out",
    "node_modules",
    ".vscode-test",
    "webview",
    "media"
  ]
}
