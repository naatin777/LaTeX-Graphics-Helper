{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "singleQuote": true,
  "semi": true,
  "tabWidth": 4,
  "useTabs": false,
  "insertFinalNewline": true,
  "ignorePatterns": ["out/**"],
  "sortPackageJson": true,
  "sortImports": {
    "groups": [
      "builtin",
      "external",
      ["internal", "subpath", "parent", "sibling", "index"]
    ],
    "newlinesBetween": true,
    "ignoreCase": true,
    "order": "asc"
  }
}
